NODE_ENV=development
PORT=5000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=itplatform
DB_USER=postgres
DB_PASSWORD=your_postgres_password

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_min_32_chars
JWT_EXPIRES_IN=8h

# Email (optional — leave blank to stub email sending)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=IT Platform <noreply@itplatform.com>

# CORS
CLIENT_URL=http://localhost:5173
